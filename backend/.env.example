APP_PORT=3700
NODE_ENV=development
DATABASE_URL="postgresql://postgres:admin@localhost:5432/survivalagent?schema=public"
JWT_SECRET="your-jwt-secret-key-here"
JWT_EXPIRES_IN=7d

# WDK (generate a testnet seed phrase)
WDK_SEED="your twelve word seed phrase here"

# AI
ANTHROPIC_API_KEY="sk-ant-your-api-key-here"

# RPC Providers (public defaults work for testnet)
BASE_SEPOLIA_RPC="https://sepolia.base.org"
ARBITRUM_SEPOLIA_RPC="https://sepolia-rollup.arbitrum.io/rpc"

# Payment Facilitators
T402_FACILITATOR_URL="https://facilitator.t402.io"
X402_FACILITATOR_URL="https://x402.org/facilitator"

# Token Addresses (Base Sepolia)
USDC_ADDRESS="0x036CbD53842c5426634e7929541eC2318f3dCF7e"

# Agent Config
AGENT_LOOP_INTERVAL="*/5 * * * *"
AGENT_MAX_TX_AMOUNT=10000000
AGENT_DAILY_SPEND_LIMIT=5000000
AGENT_MONTHLY_BURN_ESTIMATE=42000000

# ERC-8004 On-Chain Identity
ERC8004_AGENT_ID=""

# WDK Indexer API (register at wdk-api.tether.io/register)
PUBLIC_INDEXER_API_KEY=""

# WDK SecretManager (any strong passphrase, encrypts seed at rest)
WDK_ENCRYPTION_KEY=""

# Groq (free LLM fallback for DESPERATE/CRITICAL states)
GROQ_API_KEY=""

# ERC-4337 (Account Abstraction)
PIMLICO_BUNDLER_URL="https://public.pimlico.io/v2/11155111/rpc"
ETHEREUM_SEPOLIA_RPC="https://rpc.ankr.com/eth_sepolia"
